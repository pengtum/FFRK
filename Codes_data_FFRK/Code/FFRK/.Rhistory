}
# -----------------------
# 初始化存储：最终大一统表
# -----------------------
final_results <- data.frame(
model = character(),
fold  = integer(),
o     = numeric(),
p     = numeric(),
autofit_model = character(),
autofit_psill = character(),
autofit_range = character(),
autofit_kappa = character(),
stringsAsFactors = FALSE
)
# 此处还保留一个列表存储模型评估情况
cv_results <- list()
for (m in models_list) {
cv_results[[m]] <- data.frame(R2 = numeric(), MAE = numeric(), RMSE = numeric())
}
# -----------------------
# 设置总循环次数
# -----------------------
num_repeats <- 1
k_folds     <- 10 #nrow(data)
# =============== 定义进度条 ===============
total_steps <- num_repeats * length(models_list) * k_folds
pb <- progress_bar$new(
format = paste0(
"  当前进度 [:bar] :percent ",
"[模型: :model_name] ",
"[折数: :iteration/:total_fold] ",
"[重复: :rep/:total_rep] ",
"已用时: :elapsed 剩余: :eta"
),
total = total_steps,
clear = TRUE,
width = 100
)
# -----------------------
# 交叉验证主循环
# -----------------------
for (rep in 1:num_repeats) {
cat("Starting repetition:", rep, "\n")
# （1）基于 DLONG + DLAT + xx_ppm 拟合决策树，对“整个数据”进行区域划分
hier_tree <- rpart(Pb_ppm ~ DLONG + DLAT, data=data, method="anova")
# 将每个样本所属的终端节点作为“区域”
data$region <- as.factor(hier_tree$where)
# 可视化散点分区
plt <- ggplot(data, aes(x=DLONG, y=DLAT, color=region)) +
geom_point() +
theme_bw()
print(plt)
# （2）为本次重复构造 K 折
set.seed(123 + rep)
folds <- createFolds(data[[namey]], k=k_folds, list=TRUE, returnTrain=FALSE)
# （3）遍历所有模型
for (m in models_list) {
all_o <- c()
all_p <- c()
# 遍历所有折
for (fold_i in seq_len(k_folds)) {
test_idx  <- folds[[fold_i]]
test_data <- data[test_idx, ]
train_data<- data[-test_idx, ]
# 训练并预测
res <- run_fold(train_data, test_data, m, fold_i)
# 汇总本折观测/预测
all_o <- c(all_o, res$o)
all_p <- c(all_p, res$p)
# 把本折的所有样本结果存入 final_results
fold_results <- data.frame(
model = rep(m, length(res$o)),
fold  = rep(fold_i, length(res$o)),
o     = res$o,
p     = res$p,
DLONG = res$DLONG,
DLAT  = res$DLAT,
autofit_model = res$vario_model_str,
autofit_psill = res$vario_psill_str,
autofit_range = res$vario_range_str,
autofit_kappa = res$vario_kappa_str,
stringsAsFactors = FALSE
)
final_results <- rbind(final_results, fold_results)
# 更新进度条
pb$tick(tokens = list(
model_name = m,
iteration  = fold_i,
total_fold = k_folds,
rep        = rep,
total_rep  = num_repeats
))
}
# 每个模型做完K折后，计算一次评价指标
current_R2   <- R2(all_o, all_p)
current_MAE  <- MAE(all_o, all_p)
current_RMSE <- RMSE(all_o, all_p)
cv_results[[m]] <- rbind(cv_results[[m]],
data.frame(R2   = current_R2,
MAE  = current_MAE,
RMSE = current_RMSE))
}
}
# -----------------------
# 计算每个模型的平均指标
# -----------------------
average_metrics <- data.frame(model = models_list,
R2_mean   = NA,
MAE_mean  = NA,
RMSE_mean = NA)
for (m in models_list) {
average_metrics$R2_mean[average_metrics$model == m]   <- mean(cv_results[[m]]$R2, na.rm = TRUE)
average_metrics$MAE_mean[average_metrics$model == m]  <- mean(cv_results[[m]]$MAE, na.rm = TRUE)
average_metrics$RMSE_mean[average_metrics$model == m] <- mean(cv_results[[m]]$RMSE, na.rm = TRUE)
}
# 打印平均指标
print(average_metrics)
rm(list=ls())
gc()
library(doParallel) # 用于并行计算
library(caret)      # 核心训练框架
library(FFRK)       # 加载您自己的包 (假设它已经安装)
# 注册并行计算核心数
cl <- makeCluster(detectCores() - 1)
registerDoParallel(cl)
# -----------------------
# 自定义评价指标
# -----------------------
R2 <- function(o, p) {
valid_indices <- !is.na(o) & !is.na(p)
o <- o[valid_indices]
p <- p[valid_indices]
if(length(o) < 2) return(NA)
1 - sum((o - p)^2) / sum((o - mean(o))^2)
}
MAE <- function(actual, predicted) {
valid_indices <- !is.na(actual) & !is.na(predicted)
mean(abs(actual[valid_indices] - predicted[valid_indices]), na.rm = TRUE)
}
RMSE <- function(actual, predicted) {
valid_indices <- !is.na(actual) & !is.na(predicted)
sqrt(mean((actual[valid_indices] - predicted[valid_indices])^2, na.rm = TRUE))
}
# -----------------------
# 数据导入并预处理
# -----------------------
#data <- read.csv("data_Pb.csv")
#data$Pb_ppm <- log(data$Pb_ppm)
#data <- na.omit(data)
#data$DLONG <- as.numeric(data$DLONG)
#data$DLAT  <- as.numeric(data$DLAT)
data <- prepare_data(filepath = "data_Pb.csv",
value_field = "Pb_ppm",
x_field = "DLONG",
y_field = "DLAT",
log_transform = TRUE)
# -----------------------
# 提取Geo-self空间特征
# -----------------------
features <- getfeature(xo = data$DLONG, yo = data$DLAT, zo = data$Pb_ppm,
xp = data$DLONG, yp = data$DLAT)
data <- cbind(data, features)
# -----------------------
# 定义公式
# -----------------------
# 公式1：用于纯ML、rk和hier方法（不包含Geo-self空间特征特征）
formula <- Pb_ppm ~ Dlith + Dfault + Slope + Water + NDVI + MainRd + Road + SOC + pH
# 公式2：用于GRK方法（包含Geo-self空间特征）
formula2 <- as.formula(
paste("Pb_ppm", "~", paste(names(features), collapse = "+"), sep = "")
)
# 定义Y字段名
namey <- "Pb_ppm"
# -----------------------
# 定义基础ML方法与其 caret method 名称
# -----------------------
base_methods_caret <- c(lm    = "lm",
rf    = "rf",
rpart = "rpart", # 决策树
svmRadial  = "svmRadial")# 径向基核支持向量机
# -----------------------
# 构建模型列表
# -----------------------
#,paste0("GRK_", names(base_methods_caret))
models_list <- c(names(base_methods_caret),paste0("GRK_", names(base_methods_caret)))  # 分层模型
# -----------------------
# caret控制参数
# -----------------------
train_control <- trainControl(method = "CV", number=5, verboseIter=FALSE, allowParallel=TRUE)
# -----------------------
# 变差函数拟合尝试函数
# -----------------------
fit_variogram_robust <- function(vario_data, formula) {
# 直接用原本的 autofitVariogram
fit_auto <- tryCatch({
autofitVariogram(formula, vario_data,model = c("Sph"))
}, error=function(e) {
NULL
}, warning=function(w) {
NULL
})
# 若成功返回var_model
if(!is.null(fit_auto) && !is.null(fit_auto$var_model)) {
return(fit_auto$var_model)
}
return(NULL)
}
# -----------------------
# 根据模型名称识别其类型并返回相关信息
# -----------------------
get_model_info <- function(model_type) {
if(model_type == "ok") {
return(list(type="ok", caret_method=NA, use_formula=NULL))
} else if(model_type %in% names(base_methods_caret)) {
# 纯ML方法
return(list(type="ml", caret_method=base_methods_caret[model_type], use_formula=formula))
} else if(grepl("^rk_", model_type)) {
# rk_方法
base_m <- sub("^rk_", "", model_type)
return(list(type="rk", caret_method=base_methods_caret[base_m], use_formula=formula))
} else if(grepl("^GRK_", model_type)) {
# GRK_方法
base_m <- sub("^GRK_", "", model_type)
return(list(type="grk", caret_method=base_methods_caret[base_m], use_formula=formula2))
} else if(grepl("^hier_", model_type)) {
# 分层方法
base_m <- sub("^hier_", "", model_type)
return(list(type="hier", caret_method=base_methods_caret[base_m], use_formula=formula))
}
stop("Unknown model type")
}
# -----------------------
# 定义每个fold的运行函数
# -----------------------
run_fold <- function(train_data, test_data, model_type, fold_i) {
# 数据去na
train_data <- na.omit(train_data)
test_data  <- na.omit(test_data)
# 提取测试集经纬度（此时的 test_data 已去除 NA，保证行数一致）
test_coords <- test_data[, c("DLONG", "DLAT")]
# 判断数据去na后是否为空
if(nrow(train_data)==0 || nrow(test_data)==0) {
return(list(o=rep(NA, nrow(test_data)),
p=rep(NA, nrow(test_data)),
vario_model_str=rep(NA, nrow(test_data)),
vario_psill_str=rep(NA, nrow(test_data)),
vario_range_str=rep(NA, nrow(test_data)),
vario_kappa_str=rep(NA, nrow(test_data))))
}
# 提取测试集的y值
o <- test_data[[namey]]
# 如果测试集的目标列缺失
if (length(o) == 0) {
warning("Test data has no target values, skipping fold.")
return(list(o=NA, p=NA,
vario_model_str=NA,
vario_psill_str=NA,
vario_range_str=NA,
vario_kappa_str=NA))
}
# 转为空间对象
train_sp <- train_data
test_sp  <- test_data
coordinates(train_sp) <- ~ DLONG + DLAT
coordinates(test_sp)  <- ~ DLONG + DLAT
# 检测该模型类型
info <- get_model_info(model_type)
# 初始化：自动变差参数（若不涉及就用NA）
vario_model_str <- NA
vario_psill_str <- NA
vario_range_str <- NA
vario_kappa_str <- NA
# 最终预测值p
p <- rep(NA, length(o))
if(info$type == "ok") {
# OK： 直接对 ppm ~ 1 做变差函数拟合
res_auto <- fit_variogram_robust(train_sp, Pb_ppm ~ 1)
if(!is.null(res_auto)) {
# 记录变差函数参数
vario_model_str <- paste(res_auto$model, collapse=";")
vario_psill_str <- paste(round(res_auto$psill,4), collapse=";")
vario_range_str <- paste(round(res_auto$range,4), collapse=";")
vario_kappa_str <- paste(round(res_auto$kappa,4), collapse=";")
# 克里格插值
pred.krig <- krige(Pb_ppm ~ 1, train_sp, test_sp, model=res_auto)
p <- pred.krig$var1.pred
# 保存变差函数模型
saveRDS(res_auto, paste0("ok_variogram_", Sys.Date(), ".rds"))
} else {
# 变差函数失败，p保留NA
warning(paste(model_type, "variogram fitting failed, predictions set to NA."))
}
} else if(info$type == "ml") {
# 纯ML模型
model_fit <- train(info$use_formula, data=train_data,
method=info$caret_method, trControl=train_control, na.action=na.omit)
p <- predict(model_fit, newdata=test_data)
# 保存全量训练的模型
final_model <- train(info$use_formula, data=data, method=info$caret_method, trControl=train_control, na.action=na.omit)
saveRDS(final_model, paste0("final_model_", info$caret_method, "_", Sys.Date(), ".rds"))
} else if(info$type == "rk") {
# rk：ML + 对残差做OK
model_fit <- train(info$use_formula, data=train_data,
method=info$caret_method, trControl=train_control, na.action=na.omit)
pred_train <- predict(model_fit, newdata=train_data)
train_data$res <- train_data$Pb_ppm - pred_train
Aimp <- train_data$res
train_res_sp <- train_data
coordinates(train_res_sp) <- ~ DLONG + DLAT
vario_fit <- fit_variogram_robust(train_res_sp, res ~ 1)
if(!is.null(vario_fit)) {
pred.krig <- krige(res~1, train_res_sp, test_sp, model=vario_fit)
p <- predict(model_fit, newdata=test_data) + pred.krig$var1.pred
# 保存模型和变差函数
saveRDS(model_fit, paste0("rk_ml_model_", Sys.Date(), ".rds"))
saveRDS(vario_fit, paste0("rk_variogram_", Sys.Date(), ".rds"))
} else {
warning(paste(model_type, "variogram fitting failed, using only ML prediction."))
p <- predict(model_fit, newdata=test_data)
}
} else if(info$type == "grk") {
# GRK：formula2 + 残差OK
model_fit <- train(info$use_formula, data=train_data,
method=info$caret_method, trControl=train_control, na.action=na.omit)
pred_train <- predict(model_fit, newdata=train_data)
train_data$res <- train_data$Pb_ppm - pred_train
train_res_sp <- train_data
global_train_res_sp <<- train_res_sp
coordinates(train_res_sp) <- ~ DLONG + DLAT
vario_fit <- fit_variogram_robust(train_res_sp, res ~ 1)
if(!is.null(vario_fit)) {
pred.krig <- krige(res ~ 1, train_res_sp, test_sp, model=vario_fit)
p <- predict(model_fit, newdata=test_data) + pred.krig$var1.pred
# 保存当前fold的模型和变差函数（如果需要的话，这里可以注释掉）
# saveRDS(model_fit, paste0("grk_ml_model_", info$caret_method, "_fold", fold_i, "_", Sys.Date(), ".rds"))
# saveRDS(vario_fit, paste0("grk_variogram_", info$caret_method, "_fold", fold_i, "_", Sys.Date(), ".rds"))
} else {
warning(paste(model_type, "variogram fitting failed, using only GRK ML prediction."))
p <- predict(model_fit, newdata=test_data)
}
# 仅在第一个fold时训练并保存全局最终模型
if (fold_i == 1) {
final_grk_model <- train(info$use_formula, data=data,  # data 为全局完整数据
method=info$caret_method, trControl=train_control, na.action=na.omit)
pred_train_full <- predict(final_grk_model, newdata=data)
data$res <- data$Pb_ppm - pred_train_full
data_sp <- data
coordinates(data_sp) <- ~ DLONG + DLAT
final_vario_fit <- fit_variogram_robust(data_sp, res ~ 1)
if(!is.null(final_vario_fit)) {
saveRDS(final_grk_model, paste0("final_grk_ml_model_", info$caret_method, "_", Sys.Date(), ".rds"))
saveRDS(final_vario_fit, paste0("final_grk_variogram_", info$caret_method, "_", Sys.Date(), ".rds"))
} else {
warning("Final GRK variogram fitting failed, saving only ML model.")
saveRDS(final_grk_model, paste0("final_grk_ml_model_", info$caret_method, "_", Sys.Date(), ".rds"))
}
}
}
else if(info$type == "hier") {
# 分层：对每个region单独建模
unique_regions <- unique(train_data$region)
p <- numeric(nrow(test_data))
for(r in unique_regions) {
train_r <- train_data[ train_data$region == r, ]
if(nrow(train_r) == 0) next
model_fit <- train(info$use_formula, data=train_r,
method=info$caret_method, trControl=train_control, na.action=na.omit)
# 保存分区模型
saveRDS(model_fit, paste0("hier_model_region_", r, "_", Sys.Date(), ".rds"))
test_r_idx <- which(test_data$region == r)
if(length(test_r_idx) > 0) {
p[test_r_idx] <- predict(model_fit, newdata=test_data[test_r_idx, ])
}
}
# hier 不涉及任何变差函数，全部 NA
}
# 返回结果：同时带上变差函数信息(若有)；若无则NA
return(list(
o = o,
p = p,
DLONG = test_coords$DLONG,
DLAT  = test_coords$DLAT,
vario_model_str  = rep(vario_model_str, length(o)),
vario_psill_str  = rep(vario_psill_str, length(o)),
vario_range_str  = rep(vario_range_str, length(o)),
vario_kappa_str  = rep(vario_kappa_str, length(o))
))
}
# -----------------------
# 初始化存储：最终大一统表
# -----------------------
